{
  "name": "@maxipublica/auth-sync",
  "version": "0.1.0",
  "description": "Cross-frontend Auth0 session sync client (UMD + ESM).",
  "main": "dist/auth-sync.umd.js",
  "module": "dist/auth-sync.esm.js",
  "browser": "dist/auth-sync.umd.js",
  "unpkg": "dist/auth-sync.umd.min.js",
  "types": "dist/auth-sync.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/auth-sync.d.ts",
      "import": "./dist/auth-sync.esm.js",
      "require": "./dist/auth-sync.umd.js",
      "default": "./dist/auth-sync.umd.js"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.js && node scripts/copy-types.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.18.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
